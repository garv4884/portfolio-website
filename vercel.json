{
  "headers": [
    {
      "source": "/sitemaps.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!sitemaps\\.xml|robots\\.txt|favicon\\.ico|img/|css/|js/).*)",
      "destination": "/index.html"
    }
  ]
}