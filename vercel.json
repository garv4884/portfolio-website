{
  "headers": [
    {
      "source": "/sitemap.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!sitemap\\.txt|robots\\.txt|favicon\\.ico|img/|css/|js/).*)",
      "destination": "/index.html"
    }
  ]
}